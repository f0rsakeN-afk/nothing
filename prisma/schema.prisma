// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  stackId   String   @unique
  email     String   @unique
  createdAt DateTime @default(now())

  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  seenOnboarding Boolean   @default(false)
  isActive       Boolean   @default(true)

  role      Role       @default(USER)
  reports   Report[]
  feedbacks Feedback[]
  projects  Project[]
  chats     Chat[]

  customize Customize?

  @@index([stackId])
  @@index([deletedAt])
  @@index([role])
}

model Chat {
  id        String   @id @default(cuid())
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  archivedAt DateTime?

  projectId String?
  project   Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  chatFiles ChatFile[]
  messages  Message[]

  // Search context persistence - links chat to its active search
  searchResultId String?
  searchResult   SearchResult? @relation(fields: [searchResultId], references: [id], onDelete: SetNull)

  // Share settings
  visibility     String    @default("private") // "private" | "public"
  shareToken     String?   @unique @default(cuid())
  shareExpiry    DateTime?
  sharePassword  String?

  @@index([projectId])
  @@index([userId])
  @@index([deletedAt])
  @@index([archivedAt])
  @@index([userId, deletedAt])
  @@index([userId, updatedAt])
  @@index([shareToken])
}

enum SENDER {
  user
  ai
  assistant
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  deletedAt DateTime?

  sender String
  role   SENDER? @default(user)

  content String
  type    String  @default("text")

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messageFiles MessageFile[]

  // Threading support
  parentId String?
  parent   Message?  @relation("MessageThread", fields: [parentId], references: [id], onDelete: SetNull)
  replies Message[] @relation("MessageThread")

  // Search context - thread messages inherit search from parent
  searchResultId String?
  searchResult   SearchResult? @relation(fields: [searchResultId], references: [id], onDelete: SetNull)

  @@index([chatId])
  @@index([deletedAt])
  @@index([parentId])
}

enum FileStatus {
  PENDING_UPLOAD
  PROCESSING
  READY
  FAILED
}

model File {
  id        String @id @default(cuid())
  name      String
  url       String
  type      String

  // S3 storage
  s3Key     String?  // S3 object key
  s3Bucket  String?
  uploadId  String?  // S3 multipart upload ID

  // Extracted content for AI context
  extractedContent String?  // Full extracted text
  contentPreview   String?  // First 500 chars for preview
  tokenCount      Int?     // Estimated tokens

  // Status for upload/processing
  status FileStatus @default(PENDING_UPLOAD)

  createdAt DateTime @default(now())
  deletedAt DateTime?
  deletedBy String?

  // Project link (direct, not through join table for context files)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  projectFiles ProjectFile[]
  chatFiles    ChatFile[]
  messageFiles MessageFile[]

  @@index([deletedAt])
  @@index([type])
  @@index([projectId])
  @@index([status])
}

model ProjectFile {
  projectId String
  fileId    String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file    File    @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@id([projectId, fileId])
}

model MessageFile {
  messageId String
  fileId    String

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  file    File    @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@id([messageId, fileId])
}

model ChatFile {
  chatId String
  fileId String

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@id([chatId, fileId])
}

model Project {
  id          String @id @default(cuid())
  name        String @unique
  description String

  instruction String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  archivedAt DateTime?

  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chats        Chat[]
  projectFiles ProjectFile[]
  files        File[]         // Direct relation for context files

  @@index([userId])
  @@index([deletedAt])
  @@index([archivedAt])
  @@index([name])
}

model Report {
  id          String   @id @default(cuid())
  reason      String
  description String
  email       String
  image       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deletedAt])
  @@index([createdAt])
}

model Feedback {
  id        String   @id @default(cuid())
  rating    Int
  comment   String
  email     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deletedAt])
  @@index([rating])
}

model MessageFeedback {
  id        String   @id @default(cuid())
  messageId String
  chatId    String
  userId    String
  reaction  String   // "like" | "dislike"
  createdAt DateTime @default(now())

  @@index([messageId])
  @@index([chatId])
  @@index([userId])
}

model UserPreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  preferredTone     String   @default("balanced")
  detailLevel       String   @default("BALANCED")
  totalLikes        Int      @default(0)
  totalDislikes     Int      @default(0)
  likeRatio         Float    @default(0.5)  // likes / (likes + dislikes)
  lastUpdated       DateTime @updatedAt

  @@index([userId])
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  topic     String
  message   String
  createdAt DateTime @default(now())
  deletedAt DateTime?

  @@index([email])
  @@index([topic])
  @@index([deletedAt])
  @@index([createdAt])
}

enum KnowledgeDetail {
  CONCISE
  BALANCED
  DETAILED
}

model Customize {
  id              String          @id @default(cuid())
  name            String
  interest        String[]
  responseTone    String
  knowledgeDetail KnowledgeDetail @default(BALANCED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([deletedAt])
}

model Memory {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  tags      String[]
  category  String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([userId, category])
  @@index([createdAt])
}

model OnboardingData {
  id String @id @default(cuid())
}

enum TrashableModel {
  USER
  CHAT
  MESSAGE
  FILE
  PROJECT
  REPORT
  FEEDBACK
  CONTACT
  CUSTOMIZE
}

enum ArchivableModel {
  CHAT
  PROJECT
}

model Trash {
  id         String         @id @default(cuid())
  modelType  TrashableModel
  modelId    String
  data       Json
  deletedAt  DateTime       @default(now())
  deletedBy  String?
  reason     String?
  expiresAt  DateTime?

  @@index([modelType, modelId])
  @@index([deletedAt])
}

model Archive {
  id         String          @id @default(cuid())
  modelType  ArchivableModel
  modelId    String
  data       Json
  archivedAt DateTime        @default(now())
  archivedBy String?

  @@index([modelType, modelId])
  @@index([archivedAt])
}

model SearchResult {
  id        String   @id @default(cuid())
  userId    String
  query     String
  sources   Json
  createdAt DateTime @default(now())

  // Inverse relations for Chat and Message links
  chats     Chat[]
  messages  Message[]

  @@index([userId])
  @@index([createdAt])
}

model SavedSource {
  id        String   @id @default(cuid())
  userId    String
  sourceId  String   // ID from SearchSource
  title     String
  url       String
  snippet   String
  source    String   // "stackoverflow" | "reddit" | etc
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@unique([userId, sourceId])
}
