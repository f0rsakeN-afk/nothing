// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum Role {
  USER
  MODERATOR
  ADMIN
}

enum PlanTier {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  UNPAID
}

model User {
  id        String   @id @default(uuid())
  stackId   String   @unique
  email     String   @unique
  createdAt DateTime @default(now())

  updatedAt      DateTime @updatedAt
  seenOnboarding Boolean  @default(false)
  isActive       Boolean  @default(true)

  role      Role       @default(USER)
  reports   Report[]
  feedbacks Feedback[]
  projects  Project[]
  chats     Chat[]

  customize         Customize?
  settings          Settings?
  notifications     Notification[]
  notificationPrefs NotificationPrefs?

  // SaaS Premium (legacy - use planTier and planId for new system)
  plan        String   @default("free") @map("old_plan") // DEPRECATED: use planTier
  planTier    PlanTier @default(FREE)
  planId      String? // references Plan.id (null for legacy users)
  credits     Int      @default(25)
  maxChats    Int      @default(100)
  maxProjects Int      @default(2)
  maxMessages Int      @default(100)
  features    String[] @default([])

  // Relations
  subscription Subscription?
  userPlan     Plan?           @relation("UserPlan", fields: [planId], references: [id], onDelete: SetNull)
  mcpServers   McpUserServer[]

  @@index([stackId])
  @@index([role])
  @@index([planTier])
}

model Chat {
  id         String    @id @default(cuid())
  title      String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?
  pinnedAt   DateTime?

  projectId String?
  project   Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  chatFiles ChatFile[]
  messages  Message[]

  // Chat summary for long conversations
  summary ChatSummary?

  // Branch tracking
  parentChatId String?
  parentChat   Chat?   @relation("ChatBranches", fields: [parentChatId], references: [id], onDelete: SetNull)
  branches     Chat[]  @relation("ChatBranches")

  // Share settings
  visibility    String    @default("private") // "private" | "public"
  shareToken    String?   @unique @default(cuid())
  shareExpiry   DateTime?
  sharePassword String?

  @@index([projectId])
  @@index([userId])
  @@index([archivedAt])
  @@index([pinnedAt])
  @@index([userId, updatedAt])
  @@index([shareToken])
  @@index([parentChatId])
  @@index([userId, archivedAt]) // For fetching user's chats filtered by archive status
}

enum SENDER {
  user
  ai
  assistant
}

model Message {
  id     String @id @default(cuid())
  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  sender String
  role   SENDER? @default(user)

  content String
  type    String @default("text")

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messageFiles MessageFile[]

  // Threading support
  parentId String?
  parent   Message?  @relation("MessageThread", fields: [parentId], references: [id], onDelete: SetNull)
  replies  Message[] @relation("MessageThread")

  @@index([chatId])
  @@index([parentId])
  @@index([chatId, createdAt]) // For fetching messages in chronological order within a chat
}

// ---------------------------------------------------------------------------
// Chat Context Summary (for long conversations)
// ---------------------------------------------------------------------------

model ChatSummary {
  id      String @id @default(cuid())
  chatId  String @unique // One summary per chat (we summarize incrementally)
  version Int    @default(1) // If we ever re-summarize from scratch

  // The LLM-generated summary text
  summary String @db.Text

  // Structured extraction for precise retrieval
  topics   String[] @default([]) // ["authentication", "payments", "database"]
  keyFacts String[] @default([]) // ["import { prisma } from '@/lib/prisma'", "API endpoint: /api/chat"]

  // What messages this summary covers
  startMessageId String // First message included in this summary
  endMessageId   String // Last message included in this summary
  messageCount   Int // How many messages summarized

  // If conversation was branched
  parentSummaryId String?

  // Metadata
  tokenCount Int // How many tokens in original messages
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  chat     Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  parent   ChatSummary?  @relation("SummaryBranches", fields: [parentSummaryId], references: [id], onDelete: SetNull)
  branches ChatSummary[] @relation("SummaryBranches")

  @@index([chatId])
  @@index([parentSummaryId])
}

enum FileStatus {
  PENDING_UPLOAD
  PROCESSING
  READY
  FAILED
}

model File {
  id   String @id @default(cuid())
  name String
  url  String
  type String

  // S3 storage
  s3Key    String? // S3 object key
  s3Bucket String?
  uploadId String? // S3 multipart upload ID

  // Extracted content for AI context
  extractedContent String? // Full extracted text
  contentPreview   String? // First 500 chars for preview
  tokenCount       Int? // Estimated tokens

  // Status for upload/processing
  status FileStatus @default(PENDING_UPLOAD)

  createdAt DateTime @default(now())

  // Project link (direct, not through join table for context files)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  projectFiles ProjectFile[]
  chatFiles    ChatFile[]
  messageFiles MessageFile[]
  // fileChunks  FileChunk[] // Requires pgvector extension

  @@index([type])
  @@index([projectId])
  @@index([status])
  @@index([projectId, status]) // For fetching files by project with status filter
}

model ProjectFile {
  projectId String
  fileId    String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file    File    @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@id([projectId, fileId])
}

model MessageFile {
  messageId String
  fileId    String

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  file    File    @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@id([messageId, fileId])
}

model ChatFile {
  chatId String
  fileId String

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@id([chatId, fileId])
}

model Project {
  id          String @id @default(cuid())
  name        String @unique
  description String

  instruction String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?
  pinnedAt   DateTime?

  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chats        Chat[]
  projectFiles ProjectFile[]
  files        File[] // Direct relation for context files

  @@index([userId])
  @@index([archivedAt])
  @@index([pinnedAt])
  @@index([name])
}

model Report {
  id          String   @id @default(cuid())
  reason      String
  description String
  email       String
  image       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Feedback {
  id        String   @id @default(cuid())
  rating    Int
  comment   String
  email     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([rating])
}

model MessageFeedback {
  id        String   @id @default(cuid())
  messageId String
  chatId    String
  userId    String
  reaction  String // "like" | "dislike"
  createdAt DateTime @default(now())

  @@index([messageId])
  @@index([chatId])
  @@index([userId])
}

model UserPreference {
  id            String   @id @default(cuid())
  userId        String   @unique
  preferredTone String   @default("balanced")
  detailLevel   String   @default("BALANCED")
  totalLikes    Int      @default(0)
  totalDislikes Int      @default(0)
  likeRatio     Float    @default(0.5) // likes / (likes + dislikes)
  lastUpdated   DateTime @updatedAt

  @@index([userId])
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  topic     String
  message   String
  createdAt DateTime @default(now())

  @@index([email])
  @@index([topic])
  @@index([createdAt])
}

enum KnowledgeDetail {
  CONCISE
  BALANCED
  DETAILED
}

model Customize {
  id              String          @id @default(cuid())
  firstName       String          @default("")
  lastName        String          @default("")
  name            String          @default("")
  interest        String[]
  responseTone    String
  knowledgeDetail KnowledgeDetail @default(BALANCED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Settings {
  id               String   @id @default(cuid())
  userId           String   @unique
  theme            String   @default("system")
  language         String   @default("en")
  autoTitle        Boolean  @default(true)
  enterToSend      Boolean  @default(false)
  showSuggestions  Boolean  @default(true)
  compactMode      Boolean  @default(false)
  reducedMotion    Boolean  @default(false)
  streaming        Boolean  @default(true)
  codeHighlight    Boolean  @default(true)
  persistentMemory Boolean  @default(false)
  emailUpdates     Boolean  @default(true)
  emailMarketing   Boolean  @default(false)
  browserNotifs    Boolean  @default(false)
  usageAlerts      Boolean  @default(true)
  analytics        Boolean  @default(true)
  usageData        Boolean  @default(false)
  crashReports     Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Memory {
  id               String            @id @default(cuid())
  userId           String
  title            String
  content          String
  tags             String[]
  category         String?
  metadata         Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  // memoryEmbeddings MemoryEmbedding[] // Requires pgvector extension

  @@index([userId])
  @@index([userId, category])
  @@index([createdAt])
}

model OnboardingData {
  id         String   @id @default(cuid())
  userId     String   @unique
  profession String
  source     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model Notification {
  id           String    @id @default(cuid())
  userId       String
  title        String
  description  String
  read         Boolean   @default(false)
  archived     Boolean   @default(false)
  snoozedUntil DateTime?
  accent       String    @default("bg-blue-400") // CSS color class

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read, archived])
}

model NotificationPrefs {
  id         String  @id @default(cuid())
  userId     String  @unique
  newFeature Boolean @default(true)
  credits    Boolean @default(true)
  system     Boolean @default(false)
  tips       Boolean @default(true)
  security   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// SaaS Plans & Subscriptions
// ---------------------------------------------------------------------------

model Plan {
  id   String   @id // "free" | "basic" | "pro" | "enterprise"
  tier PlanTier @unique

  // Display
  name        String
  description String @db.Text

  // Pricing (in cents)
  price Int @default(0) // 0 = free

  // Polar integration
  polarPriceId   String? @unique // Polar Price ID (null for free)
  polarProductId String? // Polar Product ID

  // Limits
  credits     Int @default(25)
  maxChats    Int @default(100) // -1 = unlimited
  maxProjects Int @default(2)
  maxMessages Int @default(100) // -1 = unlimited

  // Feature-specific limits
  maxMemoryItems        Int     @default(0) // 0 = not allowed, -1 = unlimited
  maxBranchesPerChat    Int     @default(0) // 0 = not allowed
  maxFolders            Int     @default(0) // 0 = not allowed, -1 = unlimited
  maxAttachmentsPerChat Int     @default(0) // 0 = not allowed
  maxFileSizeMb         Int     @default(0) // 0 = not allowed
  canExport             Boolean @default(false)
  canApiAccess          Boolean @default(false)

  // Features (feature flags for this plan)
  features String[] @default([])

  // Scalability fields
  metadata  Json? // extra data, add/remove without schema changes
  sortOrder Int   @default(0) // for admin ordering

  // Status
  isActive  Boolean @default(true)
  isVisible Boolean @default(true) // hide from pricing page but keep for existing users
  isDefault Boolean @default(false) // default plan for new users

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users         User[]         @relation("UserPlan")
  subscriptions Subscription[]

  @@index([tier])
  @@index([isActive, isVisible])
}

model Subscription {
  id String @id @default(cuid())

  // User
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Plan
  planId String
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Restrict)

  // Polar
  polarSubscriptionId String? @unique // Polar subscription ID
  polarCustomerId     String? // Polar customer ID

  // Status
  status SubscriptionStatus @default(ACTIVE)

  // Billing
  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean   @default(false)
  canceledAt         DateTime?

  // Legacy support (old flat-rate subscriptions)
  legacyPlanId String? // old "basic"/"pro" plan identifier

  // Scalability
  metadata Json? // extra data without schema changes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([polarCustomerId])
  @@index([currentPeriodEnd])
}

// ---------------------------------------------------------------------------
// Push Notifications
// ---------------------------------------------------------------------------

model PushSubscription {
  id       String @id @default(cuid())
  userId   String
  endpoint String // Push subscription endpoint URL
  p256dh   String // User's public key for encryption
  auth     String // User's auth secret for encryption

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Composite unique - user can have multiple devices but same endpoint per device
  @@unique([userId, endpoint])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Incidents
// ---------------------------------------------------------------------------

enum IncidentStatus {
  INVESTIGATING
  IDENTIFIED
  MONITORING
  RESOLVED
}

enum IncidentSeverity {
  CRITICAL
  MAJOR
  MINOR
}

model Incident {
  id        String   @id @default(cuid())
  title     String
  status    IncidentStatus @default(INVESTIGATING)
  severity  IncidentSeverity @default(MINOR)
  message   String?
  startedAt DateTime @default(now())
  resolvedAt DateTime?

  // Components affected (stored as JSON array)
  affectedComponents String[] @default([])

  @@index([status])
  @@index([severity])
  @@index([startedAt])
}

// ---------------------------------------------------------------------------
// MCP Catalog (Pre-configured connectors marketplace)
// ---------------------------------------------------------------------------

model McpCatalogItem {
  id          String   @id @default(cuid())
  name        String
  category    String   // "dev" | "productivity" | "design" | "crm" | "payments" | "database" | "search" | "data" | "travel" | "email" | "shopping" | "other"
  url         String   @unique
  authType    String   @default("open") // "oauth" | "apikey" | "open"
  maintainer  String
  maintainerUrl String
  customIcon  String?
  isFeatured   Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isFeatured])
  @@index([isActive])
}

model McpUserServer {
  id                         String    @id @default(cuid())
  userId                     String
  name                       String
  transportType              String    @default("http")
  url                        String
  authType                   String    @default("none")
  encryptedCredentials       String?
  oauthIssuerUrl             String?
  oauthAuthorizationUrl       String?
  oauthTokenUrl              String?
  oauthScopes                String?
  oauthClientId              String?
  oauthClientSecretEncrypted String?
  oauthAccessTokenEncrypted  String?
  oauthRefreshTokenEncrypted String?
  oauthAccessTokenExpiresAt  DateTime?
  oauthConnectedAt           DateTime?
  oauthError                String?
  isEnabled                  Boolean   @default(true)
  disabledTools             String[]  @default([])
  lastTestedAt               DateTime?
  lastError                  String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isEnabled])
}

