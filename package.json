{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:full": "concurrently \"next dev\" \"bun workers\"",
    "build": "next build",
    "start": "next start",
    "start:workers": "bun workers",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:push": "bun prisma db push",
    "db:reset": "bun prisma db push --force-reset",
    "workers": "bun run services/workers.ts",
    "workers:dev": "bun --watch run services/workers.ts",
    "workers:webhook": "bun run services/workers.ts --queue=webhook",
    "workers:summarize": "bun run services/workers.ts --queue=summarization",
    "workers:email": "bun run services/workers.ts --queue=email",
    "workers:file": "bun run services/workers.ts --queue=file-processing"
  },
